---
// Cart icon shown in nav. Count badge updates reactively from localStorage.
---
<a
  href="/ostoskori"
  id="cart-icon-link"
  class="relative ml-1 p-1.5 rounded transition-colors text-white/80 hover:text-white hover:bg-white/10"
  aria-label="Ostoskori"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
  </svg>
  <span
    id="cart-badge"
    class="hidden absolute -top-1 -right-1 bg-[#d4a843] text-[#1a3a2a] text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center leading-none pointer-events-none"
  ></span>
</a>

<script>
  import { getCount } from '../scripts/cart';

  function updateBadge(count: number) {
    const badge = document.getElementById('cart-badge');
    if (!badge) return;
    if (count > 0) {
      badge.textContent = count > 9 ? '9+' : String(count);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  updateBadge(getCount());
  window.addEventListener('cart-updated', (e) => updateBadge((e as CustomEvent).detail));
  window.addEventListener('storage', () => updateBadge(getCount()));
</script>
