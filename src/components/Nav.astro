---
const navLinks = [
  { href: '/', label: 'Etusivu' },
  { href: '/artikkelit', label: 'Artikkelit' },
  { href: '/myynissa', label: 'Myynissä' },
  { href: '/kirjat', label: 'Kirjat' },
  { href: '/matti-j-kankaanpaa', label: 'Matti J. Kankaanpää' },
  { href: '/ota-yhteytta', label: 'Ota yhteyttä' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-[#1a3a2a] text-white shadow-lg sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="font-serif text-xl font-bold tracking-wide hover:text-[#d4a843] transition-colors">
        Toiset Aijat
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'bg-white/20 text-white'
                : 'text-white/80 hover:text-white hover:bg-white/10'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded hover:bg-white/10 transition-colors"
        aria-label="Avaa valikko"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-3 py-2 rounded text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
