---
import BaseLayout from './BaseLayout.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { tagToSlug } from '../utils/tags';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  sourceUrl?: string;
  blocks?: any[];
  lang?: 'fi' | 'en';
  slug?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], sourceUrl, blocks, lang = 'fi', slug: slugProp } = Astro.props;

const productBlocks = blocks?.filter(b => b.type === 'product') ?? [];
const otherBlocks = blocks?.filter(b => b.type !== 'product') ?? [];

const dateLocale = lang === 'en' ? 'en-GB' : 'fi-FI';
const formattedDate = pubDate.toLocaleDateString(dateLocale, {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tagBase = lang === 'en' ? '/en/articles/tag' : '/artikkelit/tagi';
const backHref = lang === 'en' ? '/en/articles' : '/artikkelit';
const backLabel = lang === 'en' ? '← All articles' : '← Kaikki artikkelit';
const relatedLabel = lang === 'en' ? 'Read also' : 'Lue myös';

const SITE = 'https://www.toisetaijat.fi';
const slug = slugProp ?? Astro.url.pathname.split('/').filter(Boolean).pop() ?? '';
const hreflangFi = `${SITE}/artikkelit/${slug}`;
const hreflangEn = `${SITE}/en/articles/${slug}`;
const canonicalUrl = `${SITE}${Astro.url.pathname}`;

// Related articles: same collection, overlapping tags, exclude self
const collection = lang === 'en' ? 'articles_en' : 'articles';
const allArticles = await getCollection(collection as any, ({ data }: any) => !data.draft);
const related = allArticles
  .filter((a: any) => a.id !== slug && a.data.tags?.some((t: string) => tags.includes(t)))
  .sort((a: any, b: any) => {
    const commonA = a.data.tags?.filter((t: string) => tags.includes(t)).length ?? 0;
    const commonB = b.data.tags?.filter((t: string) => tags.includes(t)).length ?? 0;
    return commonB - commonA || b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);

const articleBase = lang === 'en' ? '/en/articles' : '/artikkelit';

const AUTHOR_CUTOFF = new Date('2017-11-01');
const isMatti = pubDate < AUTHOR_CUTOFF;
const author = isMatti ? 'Matti J. Kankaanpää' : 'Jarle M. Alvheim';
const authorUrl = isMatti ? `${SITE}/matti-j-kankaanpaa` : undefined;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(description ? { description } : {}),
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
    ...(authorUrl ? { url: authorUrl } : {}),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Toiset Aijat',
    url: SITE,
  },
  url: canonicalUrl,
  ...(heroImage ? { image: heroImage.startsWith('http') ? heroImage : `${SITE}${heroImage}` } : {}),
});

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: lang === 'en' ? 'Home' : 'Etusivu', item: SITE + (lang === 'en' ? '/en/' : '/') },
    { '@type': 'ListItem', position: 2, name: lang === 'en' ? 'Articles' : 'Artikkelit', item: SITE + (lang === 'en' ? '/en/articles/' : '/artikkelit/') },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={heroImage}
  ogType="article"
  hreflangFi={hreflangFi}
  hreflangEn={hreflangEn}
  lang={lang}>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={author} />
    <meta name="author" content={author} />
    <script type="application/ld+json" set:html={jsonLd} />
    <script type="application/ld+json" set:html={breadcrumbLd} />
  </Fragment>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        width={900}
        height={400}
        loading="eager"
        decoding="async"
        class="w-full h-64 object-cover rounded-lg mb-8 shadow"
      />
    )}
    <header class="mb-8 border-b border-gray-200 pb-6">
      <p class="text-sm text-[#44403c] uppercase tracking-wide mb-2">{formattedDate}</p>
      <h1 class="text-3xl sm:text-4xl font-serif font-bold text-[#1a3a2a] leading-tight">
        {title}
      </h1>
      {description && (
        <p class="mt-3 text-lg text-[#44403c] leading-relaxed">{description}</p>
      )}
      {tags.length > 0 && (
        <div class="flex gap-2 mt-4 flex-wrap">
          {tags.map(tag => (
            <a
              href={`${tagBase}/${tagToSlug(tag)}`}
              class="text-xs bg-[#1a3a2a]/10 text-[#1a3a2a] hover:bg-[#1a3a2a]/20 px-2.5 py-1 rounded-full transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none
      prose-headings:font-serif prose-headings:text-[#1a3a2a]
      prose-p:text-[#1c1c1c] prose-p:leading-relaxed
      prose-a:text-[#2d6a4f] prose-a:font-medium hover:prose-a:underline
      prose-strong:text-[#1a3a2a]
      prose-blockquote:border-l-[#8b6914] prose-blockquote:text-[#44403c]
      prose-li:text-[#1c1c1c]
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3">
      {productBlocks.length > 0 && (
        <div class="not-prose float-right ml-6 mb-6 w-64 clear-right">
          <BlockRenderer blocks={productBlocks} compact={true} />
        </div>
      )}
      <slot />
    </div>

    {otherBlocks.length > 0 && (
      <BlockRenderer blocks={otherBlocks} />
    )}

    <footer class="mt-12 pt-6 border-t border-gray-200 space-y-4">
      <a href={backHref} class="inline-block text-[#2d6a4f] hover:underline font-medium">
        {backLabel}
      </a>
    </footer>

    {related.length > 0 && (
      <aside class="mt-10 pt-8 border-t border-gray-200">
        <h2 class="font-serif text-xl font-bold text-[#1a3a2a] mb-5">{relatedLabel}</h2>
        <div class="space-y-3">
          {related.map((a: any) => (
            <a
              href={`${articleBase}/${a.id}`}
              class="group flex gap-4 p-3 rounded-lg border border-gray-100 hover:border-[#2d6a4f] hover:bg-[#f0f7f3] transition-all"
            >
              {a.data.heroImage && (
                <img
                  src={a.data.heroImage}
                  alt=""
                  width={72}
                  height={72}
                  loading="lazy"
                  decoding="async"
                  class="w-18 h-18 rounded object-cover flex-shrink-0"
                />
              )}
              <div class="min-w-0">
                <p class="text-xs text-[#78716c] mb-0.5">
                  {a.data.pubDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long' })}
                </p>
                <h3 class="font-serif font-bold text-[#1a3a2a] group-hover:text-[#2d6a4f] leading-snug text-sm">
                  {a.data.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </aside>
    )}
  </article>
</BaseLayout>
