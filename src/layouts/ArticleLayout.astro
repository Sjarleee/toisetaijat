---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  sourceUrl?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], sourceUrl } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('fi-FI', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full h-64 object-cover rounded-lg mb-8 shadow"
      />
    )}
    <header class="mb-8 border-b border-gray-200 pb-6">
      <p class="text-sm text-[#6b7280] uppercase tracking-wide mb-2">{formattedDate}</p>
      <h1 class="text-3xl sm:text-4xl font-serif font-bold text-[#1a3a2a] leading-tight">
        {title}
      </h1>
      {description && (
        <p class="mt-3 text-lg text-[#6b7280] leading-relaxed">{description}</p>
      )}
      {tags.length > 0 && (
        <div class="flex gap-2 mt-4 flex-wrap">
          {tags.map(tag => (
            <a
              href={`/artikkelit/tagi/${encodeURIComponent(tag)}`}
              class="text-xs bg-[#1a3a2a]/10 text-[#1a3a2a] hover:bg-[#1a3a2a]/20 px-2.5 py-1 rounded-full transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none
      prose-headings:font-serif prose-headings:text-[#1a3a2a]
      prose-p:text-[#1c1c1c] prose-p:leading-relaxed
      prose-a:text-[#2d6a4f] prose-a:font-medium hover:prose-a:underline
      prose-strong:text-[#1a3a2a]
      prose-blockquote:border-l-[#8b6914] prose-blockquote:text-[#6b7280]
      prose-li:text-[#1c1c1c]
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3">
      <slot />
    </div>

    <footer class="mt-12 pt-6 border-t border-gray-200 space-y-4">
      {sourceUrl && (
        <p class="text-sm text-[#6b7280]">
          Alkuperäinen julkaisu: <a href={sourceUrl} class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener noreferrer">{sourceUrl}</a>
        </p>
      )}
      <a href="/artikkelit" class="inline-block text-[#2d6a4f] hover:underline font-medium">
        ← Kaikki artikkelit
      </a>
    </footer>
  </article>
</BaseLayout>
