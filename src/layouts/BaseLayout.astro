---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  lang?: 'fi' | 'en';
  hreflangFi?: string;
  hreflangEn?: string;
}

const {
  title,
  description = 'Matti J. Kankaanpään kirjallisuus- ja muistosivu – sukututkimus, historia, kirjat',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  lang = 'fi',
  hreflangFi,
  hreflangEn,
} = Astro.props;

const siteTitle = title === 'Toiset Aijat' ? title : `${title} – Toiset Aijat`;
const SITE = 'https://www.toisetaijat.fi';
const canonicalUrl = `${SITE}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    {hreflangFi && <link rel="alternate" hreflang="fi" href={hreflangFi} />}
    {hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
    {(hreflangFi || hreflangEn) && <link rel="alternate" hreflang="x-default" href={hreflangFi ?? hreflangEn} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <slot name="head" />
    <title>{siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-[#1a3a2a] focus:font-semibold focus:rounded focus:shadow-lg">
      {lang === 'en' ? 'Skip to main content' : 'Siirry pääsisältöön'}
    </a>
    <Nav lang={lang} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieBanner lang={lang} />
  </body>
</html>
