---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by year
const byYear: Record<number, typeof sorted> = {};
for (const article of sorted) {
  const year = article.data.pubDate.getFullYear();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(article);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

// Build tag cloud with counts
const tagCounts: Record<string, number> = {};
for (const article of allArticles) {
  for (const tag of article.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Artikkelit" description="Kaikki Matti J. Kankaanpään artikkelit sukututkimuksesta ja historiasta">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-2">Artikkelit</h1>
    <p class="text-[#6b7280] mb-10 text-lg">
      Sukututkimukseen ja Suomen historiaan liittyvät artikkelit ja esitelmät.
    </p>

    <div class="flex flex-col lg:flex-row gap-10">
      <!-- Article list -->
      <div class="flex-1 min-w-0">
        {sorted.length === 0 && (
          <p class="text-[#6b7280]">Artikkeleita ei vielä ole julkaistu.</p>
        )}

        {years.map(year => (
          <section class="mb-12">
            <h2 class="font-serif text-xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-2 mb-6">{year}</h2>
            <div class="space-y-4">
              {byYear[year].map(article => (
                <a
                  href={`/artikkelit/${article.id}`}
                  class="group flex gap-4 p-4 bg-white rounded-lg border border-gray-200 hover:border-[#2d6a4f] hover:shadow-sm transition-all duration-200"
                >
                  {article.data.heroImage ? (
                    <div class="flex-shrink-0 w-20 h-20 rounded overflow-hidden bg-gray-100">
                      <img
                        src={article.data.heroImage}
                        alt=""
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="flex-shrink-0 w-20 text-right pt-1">
                      <span class="text-xs text-[#6b7280]">
                        {article.data.pubDate.toLocaleDateString('fi-FI', { day: 'numeric', month: 'numeric' })}
                      </span>
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    {article.data.heroImage && (
                      <span class="text-xs text-[#6b7280]">
                        {article.data.pubDate.toLocaleDateString('fi-FI', { day: 'numeric', month: 'numeric' })}
                      </span>
                    )}
                    <h3 class="font-serif text-base font-bold text-[#1a3a2a] group-hover:text-[#2d6a4f] leading-snug">
                      {article.data.title}
                    </h3>
                    {article.data.description && (
                      <p class="text-sm text-[#6b7280] mt-1 leading-relaxed line-clamp-2">
                        {article.data.description}
                      </p>
                    )}
                    {article.data.tags.length > 0 && (
                      <div class="flex gap-1.5 mt-2 flex-wrap">
                        {article.data.tags.map(tag => (
                          <span class="text-xs bg-[#1a3a2a]/10 text-[#1a3a2a] px-2 py-0.5 rounded-full">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- Sidebar: tag cloud -->
      <aside class="lg:w-56 flex-shrink-0">
        <div class="sticky top-6">
          <h2 class="font-serif text-lg font-bold text-[#1a3a2a] mb-4">Aihealueet</h2>
          <div class="flex flex-wrap gap-2">
            {tags.map(([tag, count]) => (
              <a
                href={`/artikkelit/tagi/${encodeURIComponent(tag)}`}
                class="inline-flex items-center gap-1 text-sm bg-white border border-gray-200 hover:border-[#2d6a4f] hover:text-[#2d6a4f] text-[#374151] px-3 py-1.5 rounded-full transition-colors"
              >
                {tag}
                <span class="text-xs text-[#9ca3af]">{count}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
