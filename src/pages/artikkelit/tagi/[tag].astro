---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { tagToSlug, slugToTag } from '../../../utils/tags';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  const allTags = [...new Set(allArticles.flatMap(a => a.data.tags))];

  return allTags.map(tag => ({
    params: { tag: tagToSlug(tag) },
    props: {
      tag,
      articles: allArticles
        .filter(a => a.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, articles } = Astro.props;
---

<BaseLayout
  title={`Aihealue: ${tag}`}
  description={`Artikkelit aiheesta ${tag} – Toiset Aijat`}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-sm text-[#44403c] mb-6">
      <a href="/artikkelit" class="hover:text-[#2d6a4f]">Artikkelit</a>
      <span class="mx-2">›</span>
      <span>{tag}</span>
    </nav>

    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-2">
      {tag}
    </h1>
    <p class="text-[#44403c] mb-10">
      {articles.length} artikkeli{articles.length !== 1 ? 'a' : ''}
    </p>

    <div class="space-y-4">
      {articles.map(article => (
        <a
          href={`/artikkelit/${article.id}`}
          class="group flex gap-5 p-4 bg-white rounded-lg border border-gray-200 hover:border-[#2d6a4f] hover:shadow-sm transition-all duration-200"
        >
          <div class="flex-shrink-0 w-24 text-right">
            <span class="text-xs text-[#44403c]">
              {article.data.pubDate.toLocaleDateString('fi-FI', {
                day: 'numeric',
                month: 'numeric',
                year: 'numeric',
              })}
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a] group-hover:text-[#2d6a4f] leading-snug">
              {article.data.title}
            </h3>
            {article.data.description && (
              <p class="text-sm text-[#44403c] mt-1 leading-relaxed line-clamp-2">
                {article.data.description}
              </p>
            )}
            <div class="flex gap-1.5 mt-2 flex-wrap">
              {article.data.tags.map(t => (
                <span
                  class={`text-xs px-2 py-0.5 rounded-full ${
                    t === tag
                      ? 'bg-[#1a3a2a] text-white'
                      : 'bg-[#1a3a2a]/10 text-[#1a3a2a]'
                  }`}
                >
                  {t}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
