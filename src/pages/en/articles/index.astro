---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles_en', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const byYear: Record<number, typeof sorted> = {};
for (const article of sorted) {
  const year = article.data.pubDate.getFullYear();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(article);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const tagCounts: Record<string, number> = {};
for (const article of allArticles) {
  for (const tag of article.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Articles" description="Articles on Finnish genealogy, cavalry history and regional history by Matti J. Kankaanpää" lang="en">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-2">Articles</h1>
    <p class="text-[#44403c] mb-10 text-lg">
      Articles and studies on Finnish genealogy and history.
    </p>

    <div class="flex flex-col lg:flex-row gap-10">
      <div class="flex-1 min-w-0">
        {sorted.length === 0 && (
          <p class="text-[#44403c]">No articles have been published yet. Check back soon.</p>
        )}

        {years.map(year => (
          <section class="mb-12">
            <h2 class="font-serif text-xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-2 mb-6">{year}</h2>
            <div class="space-y-4">
              {byYear[year].map(article => (
                <a
                  href={`/en/articles/${article.id}`}
                  class="group flex gap-4 p-4 bg-white rounded-lg border border-gray-200 hover:border-[#2d6a4f] hover:shadow-sm transition-all duration-200"
                >
                  {article.data.heroImage ? (
                    <div class="flex-shrink-0 w-20 h-20 rounded overflow-hidden bg-gray-100">
                      <img src={article.data.heroImage} alt="" class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  ) : (
                    <div class="flex-shrink-0 w-20 h-20 rounded bg-[#1a3a2a]/5 flex items-center justify-center">
                      <span class="text-[#1a3a2a]/20 text-2xl">✦</span>
                    </div>
                  )}
                  <div class="min-w-0">
                    <p class="text-xs text-[#78716c] mb-1">
                      {article.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </p>
                    <h3 class="font-serif font-bold text-[#1a3a2a] group-hover:text-[#2d6a4f] transition-colors leading-snug">
                      {article.data.title}
                    </h3>
                    {article.data.description && (
                      <p class="text-sm text-[#44403c] mt-1 line-clamp-2">{article.data.description}</p>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      {tags.length > 0 && (
        <aside class="lg:w-64 shrink-0">
          <h2 class="font-semibold text-[#1a3a2a] mb-4 text-sm uppercase tracking-wide">Tags</h2>
          <div class="flex flex-wrap gap-2">
            {tags.map(([tag, count]) => (
              <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-[#1a3a2a]/5 text-[#1a3a2a] rounded-full text-xs">
                {tag}
                <span class="text-[#78716c]">({count})</span>
              </span>
            ))}
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
