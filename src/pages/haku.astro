---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const searchData = allArticles.map(a => ({
  id: a.id,
  title: a.data.title,
  description: a.data.description ?? '',
  tags: a.data.tags,
  date: a.data.pubDate.toLocaleDateString('fi-FI', { year: 'numeric', month: 'long', day: 'numeric' }),
  url: `/artikkelit/${a.id}`,
}));
---

<BaseLayout title="Haku" description="Hae artikkeleita">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-6">Haku</h1>

    <div class="relative mb-8">
      <input
        id="search-input"
        type="search"
        placeholder="Hae artikkeleita..."
        autofocus
        class="w-full px-4 py-3 pl-11 border border-gray-400 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-[#2d6a4f]"
      />
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
      </svg>
    </div>

    <p id="result-count" class="text-sm text-[#44403c] mb-4"></p>

    <div id="results" class="space-y-3"></div>
    <p id="no-results" class="hidden text-[#44403c]">Ei tuloksia.</p>
  </div>
</BaseLayout>

<script define:vars={{ searchData }}>
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('results');
  const noResults = document.getElementById('no-results');
  const countEl = document.getElementById('result-count');

  function highlight(text, query) {
    if (!query) return text;
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark class="bg-yellow-200 rounded-sm px-0.5">$1</mark>');
  }

  function render(articles, query) {
    resultsEl.innerHTML = '';
    if (articles.length === 0) {
      noResults.classList.remove('hidden');
      countEl.textContent = '';
      return;
    }
    noResults.classList.add('hidden');
    countEl.textContent = `${articles.length} artikkeli${articles.length === 1 ? '' : 'a'}`;

    for (const a of articles) {
      const card = document.createElement('a');
      card.href = a.url;
      card.className = 'group block p-4 bg-white rounded-lg border border-gray-200 hover:border-[#2d6a4f] hover:shadow-sm transition-all duration-200';
      card.innerHTML = `
        <p class="text-xs text-[#44403c] mb-1">${a.date}</p>
        <h2 class="font-serif text-base font-bold text-[#1a3a2a] group-hover:text-[#2d6a4f] leading-snug mb-1">${highlight(a.title, query)}</h2>
        ${a.description ? `<p class="text-sm text-[#44403c] line-clamp-2">${highlight(a.description, query)}</p>` : ''}
        ${a.tags.length ? `<div class="flex flex-wrap gap-1 mt-2">${a.tags.map(t => `<span class="text-xs bg-[#eaf4ee] text-[#2d6a4f] rounded px-2 py-0.5">${t}</span>`).join('')}</div>` : ''}
      `;
      resultsEl.appendChild(card);
    }
  }

  function search(query) {
    if (!query.trim()) {
      render([], '');
      countEl.textContent = '';
      return;
    }
    const q = query.toLowerCase();
    const hits = searchData.filter(a =>
      a.title.toLowerCase().includes(q) ||
      a.description.toLowerCase().includes(q) ||
      a.tags.some(t => t.toLowerCase().includes(q))
    );
    render(hits, query);
  }

  // Check URL param on load
  const params = new URLSearchParams(window.location.search);
  const q = params.get('q') ?? '';
  if (q) {
    input.value = q;
    search(q);
  }

  input.addEventListener('input', e => {
    const val = e.target.value;
    // Update URL without navigation
    const url = new URL(window.location.href);
    if (val) url.searchParams.set('q', val); else url.searchParams.delete('q');
    history.replaceState(null, '', url);
    search(val);
  });
</script>
