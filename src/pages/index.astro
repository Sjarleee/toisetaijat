---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recentArticles = allArticles
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Toiset Aijat" description="Matti J. Kankaanpään kirjallisuus- ja muistosivu – sukututkimus, historia, kirjat">

  <!-- Hero -->
  <section class="bg-[#1a3a2a] text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="text-[#d4a843] text-sm font-semibold uppercase tracking-widest mb-4">
          Sukututkimus · Historia · Kirjat
        </p>
        <h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
          Toiset Aijat
        </h1>
        <p class="text-white/80 text-lg sm:text-xl leading-relaxed mb-8">
          Matti J. Kankaanpään (1943–2017) kirjallisuus- ja muistosivu.
          Sukututkimuksen asiantuntija Virroilta – artikkelit, kirjat ja tutkimukset
          suomalaisesta historiasta.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/artikkelit" class="bg-[#d4a843] text-[#1a3a2a] px-6 py-3 rounded-md font-semibold hover:bg-[#b8922e] transition-colors">
            Lue artikkelit
          </a>
          <a href="/myynissa" class="border border-white/40 text-white px-6 py-3 rounded-md font-semibold hover:bg-white/10 transition-colors">
            Tilaa kirjoja
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Info bar -->
  <section class="bg-[#d4a843]/10 border-y border-[#d4a843]/30">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4">
      <p class="text-sm text-[#6b4f0a] text-center">
        <strong>Huom:</strong> Kirjojen postitus seuraavan kerran 20. toukokuuta – 24. heinäkuuta 2025.
        <a href="/myynissa" class="underline hover:no-underline ml-1">Tilaa etukäteen →</a>
      </p>
    </div>
  </section>

  <!-- Recent articles -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-serif text-2xl sm:text-3xl font-bold text-[#1a3a2a]">Uusimmat artikkelit</h2>
      <a href="/artikkelit" class="text-[#2d6a4f] text-sm font-medium hover:underline">Kaikki artikkelit →</a>
    </div>

    {recentArticles.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {recentArticles.map(article => (
          <a
            href={`/artikkelit/${article.id}`}
            class="group block bg-white rounded-lg border border-gray-200 hover:border-[#2d6a4f] hover:shadow-md transition-all duration-200 overflow-hidden"
          >
            {article.data.heroImage && (
              <img
                src={article.data.heroImage}
                alt={article.data.title}
                class="w-full h-40 object-cover"
              />
            )}
            <div class="p-5">
              <p class="text-xs text-[#6b7280] mb-2">
                {article.data.pubDate.toLocaleDateString('fi-FI', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h3 class="font-serif text-lg font-bold text-[#1a3a2a] group-hover:text-[#2d6a4f] leading-snug mb-2">
                {article.data.title}
              </h3>
              {article.data.description && (
                <p class="text-sm text-[#6b7280] leading-relaxed line-clamp-3">
                  {article.data.description}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-[#6b7280]">Ei artikkeleita vielä.</p>
    )}
  </section>

  <!-- Books CTA -->
  <section class="bg-[#f5f0e8] border-y border-[#e5d9c3]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 grid sm:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="font-serif text-2xl sm:text-3xl font-bold text-[#1a3a2a] mb-4">
          Kirjat ja artikkelit
        </h2>
        <p class="text-[#4a4a4a] leading-relaxed mb-6">
          Matti J. Kankaanpää kirjoitti laajasti suomalaisesta sukututkimuksesta
          ja historiasta. Kirjoja ja artikkeleita on saatavilla myös e-kirjoina.
          Tilaukset postitetaan Norjasta säännöllisten Suomen-käyntien yhteydessä.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href="/myynissa" class="bg-[#1a3a2a] text-white px-5 py-2.5 rounded-md font-medium hover:bg-[#2d6a4f] transition-colors">
            Katso saatavilla olevat
          </a>
          <a href="/kirjat" class="border border-[#1a3a2a] text-[#1a3a2a] px-5 py-2.5 rounded-md font-medium hover:bg-[#1a3a2a] hover:text-white transition-colors">
            Kaikki kirjat
          </a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white rounded-lg p-5 border border-gray-200 shadow-sm text-center">
          <div class="text-3xl font-bold text-[#1a3a2a] font-serif">€4</div>
          <div class="text-sm text-[#6b7280] mt-1">per artikkeli</div>
        </div>
        <div class="bg-white rounded-lg p-5 border border-gray-200 shadow-sm text-center">
          <div class="text-3xl font-bold text-[#1a3a2a] font-serif">PDF</div>
          <div class="text-sm text-[#6b7280] mt-1">sähköpostitse</div>
        </div>
        <div class="bg-white rounded-lg p-5 border border-gray-200 shadow-sm text-center">
          <div class="text-3xl font-bold text-[#1a3a2a] font-serif">€80</div>
          <div class="text-sm text-[#6b7280] mt-1">kaikki artikkelit</div>
        </div>
        <div class="bg-white rounded-lg p-5 border border-gray-200 shadow-sm text-center">
          <div class="text-3xl font-bold text-[#1a3a2a] font-serif">📚</div>
          <div class="text-sm text-[#6b7280] mt-1">myös e-kirjat</div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
