---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'kirjat');
const byIsbn = new Map<string, never>();
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-2">Julkaisuluettelo</h1>
    <p class="text-[#44403c] mb-10 text-lg">
      {page.data.introText ?? 'Matti J. Kankaanpään (1943–2017) kirjat, sukukirjat, historiikit ja lehtiartikkelit.'}
    </p>

    <!-- Navigaatio -->
    <nav class="flex flex-wrap gap-3 mb-12 text-sm">
      <a href="#kirjat" class="px-3 py-1.5 bg-[#1a3a2a]/10 text-[#1a3a2a] rounded-full hover:bg-[#1a3a2a]/20">Kirjat</a>
      <a href="#lehtiartikkelit" class="px-3 py-1.5 bg-[#1a3a2a]/10 text-[#1a3a2a] rounded-full hover:bg-[#1a3a2a]/20">Lehtiartikkelit</a>
    </nav>

    <!-- KIRJAT -->
    <section id="kirjat" class="mb-16">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-8">Kirjat</h2>
      <ol class="space-y-5">

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2020</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Karjalan Ratsurykmentti – Matrikkeli 1700–1737</p>
            <p class="text-sm text-[#44403c]">E-kirja. <a href="https://play.google.com/store/books/details/Matti_J_Kankaanp%C3%A4%C3%A4_Karjalan_Ratsurykmentti_Matrikk?id=fx4REAAAQBAJ" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Tilaa Google Play -kaupasta</a></p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2018</span>
          <div>
            <p class="font-medium text-[#1a3a2a]"><a href="/artikkelit/virrat-150-vuotta-1867-2017-kuvin-ja-sanoin" class="hover:text-[#2d6a4f] hover:underline">Kimaltelevilta vesiltä – Virrat kuvin ja sanoin 1867–2018</a></p>
            <p class="text-sm text-[#44403c]">Matti J. Kankaanpää ja Lea Lerkkanen. Seinäjoki 2018. Kustantaja: Virtain Kaupunki. 338 s. ISBN 978-952-69101-0-9.</p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2016</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Suomalainen ratsuväki Ruotsin ajalla</p>
            <p class="text-sm text-[#44403c]">
              Porvoo 2016. T:mi Toiset Aijat. 790 s. ISBN 978-952-99106-9-4.
              {(() => {
                const p = byIsbn.get('978-952-99106-9-4');
                if (p && p.availability === 'available' && p.price) return (
                  <span class="ml-2">
                    <span class="font-semibold text-[#1a3a2a]">€{p.price}</span>
                    {p.shippingPrice && <span class="text-[#78716c]"> + €{p.shippingPrice} posti</span>}
                    {' · '}
                    <a href={p.orderUrl ?? '/myynissa'} class="text-[#2d6a4f] hover:underline" target={p.orderUrl ? '_blank' : undefined} rel={p.orderUrl ? 'noopener noreferrer' : undefined}>Tilaa tästä</a>
                  </span>
                );
                return <a href="/myynissa" class="ml-2 text-[#2d6a4f] hover:underline">Tilaa tästä</a>;
              })()}
            </p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2014</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">IsoKakkonen I – Pyhäselän Hammaslahdessa eläneen Yrjö Kakkosen jälkeläisiä 1600-luvun lopulta nykypäivään</p>
            <p class="text-sm text-[#44403c]">Yhdessä Jouni Kakkosen kanssa. Joensuu 2014. Kakkosten sukuyhdistys ry. ISBN 978-952-93-4629-5. <em>Vuoden sukukirja 2015.</em></p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2011</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Vilhuset Jääskestä Savoon ja Multialle</p>
            <p class="text-sm text-[#44403c]">Sukuseura Vilhunen ry. Mikkeli 2011. ISBN 978-952-92-9967-6.</p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2011</span>
          <div>
            <p class="font-medium text-[#1a3a2a]"><a href="/artikkelit/ison-vihan-aika-suomessa" class="hover:text-[#2d6a4f] hover:underline">Ruoveden komppanian miehet Suomen sodassa</a></p>
            <p class="text-sm text-[#44403c]">Jyväskylä 2011. ISBN 978-952-99106-8-7. <a href="/myynissa" class="text-[#2d6a4f] hover:underline">Tilaa tästä</a></p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2008</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Ruoveden ja Keuruun käräjäpöytäkirjoista 1722–1746</p>
            <p class="text-sm text-[#44403c]">Jyväskylä 2008. T:mi Toiset Aijat. 254 s. ISBN 978-952-99106-7-0. <a href="/myynissa" class="text-[#2d6a4f] hover:underline">Tilaa tästä</a></p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2007</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Letonmäen suku</p>
            <p class="text-sm text-[#44403c]">Keuruskopio Oy 2007. Koonnut Kaija Raiski, toimittanut Matti J. Kankaanpää. ISBN 978-952-92-3175-1.</p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2006</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Karjalainen Karilainen – Nimi ja suku historian myrskyissä</p>
            <p class="text-sm text-[#44403c]">Jyväskylä 2006. T:mi Toiset Aijat. 238 s. ISBN 952-99106-6-5. <a href="/myynissa" class="text-[#2d6a4f] hover:underline">Tilaa tästä</a></p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2005</span>
          <div>
            <p class="font-medium text-[#1a3a2a]">Ruoveden ja Keuruun käräjäpöytäkirjoista 1683–1711</p>
            <p class="text-sm text-[#44403c]">Saarijärvi 2005. T:mi Toiset Aijat. 280 s. ISBN 952-99106-5-7. <a href="https://play.google.com/store/books/details?id=H4mvDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">E-kirja Google Play -kaupasta</a></p>
          </div>
        </li>

        <li class="flex gap-4">
          <span class="text-sm text-[#78716c] w-12 shrink-0 pt-0.5 text-right">2004</span>
