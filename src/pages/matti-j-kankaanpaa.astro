---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'matti-j-kankaanpaa');
const { Content } = await render(page);
const { photo, photoAlt, photoCaption, photoPlacement = 'right' } = page.data;
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-6">{page.data.title}</h1>

    {photo && photoPlacement === 'top' && (
      <figure class="mb-8">
        <img src={photo} alt={photoAlt ?? page.data.title} class="w-full rounded-lg shadow object-cover max-h-80" />
        {photoCaption && <figcaption class="text-sm text-[#6b7280] mt-2 text-center italic">{photoCaption}</figcaption>}
      </figure>
    )}

    {photo && photoPlacement === 'full' && (
      <figure class="mb-8 -mx-4 sm:-mx-6">
        <img src={photo} alt={photoAlt ?? page.data.title} class="w-full object-cover max-h-96" />
        {photoCaption && <figcaption class="text-sm text-[#6b7280] mt-2 text-center italic px-4 sm:px-6">{photoCaption}</figcaption>}
      </figure>
    )}

    {photo && (photoPlacement === 'right' || photoPlacement === 'left') && (
      <figure class={`not-prose mb-6 sm:mb-2 sm:w-48 ${photoPlacement === 'right' ? 'sm:float-right sm:ml-6' : 'sm:float-left sm:mr-6'}`}>
        <img src={photo} alt={photoAlt ?? page.data.title} class="w-full rounded-lg shadow" />
        {photoCaption && <figcaption class="text-sm text-[#6b7280] mt-2 text-center italic">{photoCaption}</figcaption>}
      </figure>
    )}

    <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-[#1a3a2a] prose-a:text-[#2d6a4f] clearfix">
      <Content />
    </div>
  </div>
</BaseLayout>
