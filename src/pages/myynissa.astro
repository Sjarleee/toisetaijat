---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { entryToBook, entryToCollection } from '../data/products';
import { getEntry, getCollection } from 'astro:content';

const allBookEntries = await getCollection('books');
const allCollectionEntries = await getCollection('articleCollections');

const books = allBookEntries
  .filter(e => e.data.productType === 'book')
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .map(entryToBook);

const ebooks = allBookEntries
  .filter(e => e.data.productType === 'ebook')
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .map(entryToBook);

const singleArticles = allBookEntries
  .filter(e => e.data.productType === 'single-article')
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .map(entryToBook);

const articleCollections = allCollectionEntries
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .map(entryToCollection);

const availableBooks = books.filter(b => b.availability !== 'soldout' && b.availability !== 'external');
const externalBooks = books.filter(b => b.availability === 'external');

const page = await getEntry('pages', 'myynissa');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-2">{page.data.title}</h1>
    <p class="text-[#6b7280] mb-4 text-lg">Kirjat ja artikkelikokoelmat tilattavissa.</p>

    <!-- Shipping notice -->
    {page.data.deliveryNote && (
    <div class="bg-[#d4a843]/10 border border-[#d4a843]/40 rounded-lg p-4 mb-10 text-sm text-[#6b4f0a]">
      {page.data.deliveryNote}
    </div>
    )}

    <!-- KIRJAT -->
    <section class="mb-14">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-6">Kirjat</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {availableBooks.map(book => (
          <ProductCard product={book} variant="full" />
        ))}
      </div>
      {externalBooks.length > 0 && (
        <div class="mt-6 space-y-2">
          {externalBooks.map(book => (
            <ProductCard product={book} variant="compact" />
          ))}
        </div>
      )}
      <p class="text-sm text-[#6b7280] mt-4">
        Muita kirjoja: katso <a href="/kirjat" class="text-[#2d6a4f] hover:underline">julkaisuluettelo</a>. Saatavuus vaihtelee — kysy sähköpostitse.
      </p>
    </section>

    <!-- E-KIRJAT -->
    <section class="mb-14">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-6">E-kirjat</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {ebooks.map(book => (
          <ProductCard product={book} variant="full" />
        ))}
      </div>
    </section>

    <!-- ARTIKKELIKOKOELMAT & E-ARTIKKELIT -->
    <section class="mb-12">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-2">E-artikkelit</h2>
      <p class="text-sm text-[#6b7280] mb-6">
        PDF-artikkeleita ja e-artikkeleita. Toimitetaan sähköpostitse tai Google Play -kaupasta. €4 per artikkeli tai kaikki sarjan artikkelit yhteishintaan.
      </p>

      <!-- Yksittäiset artikkelit -->
      {singleArticles.length > 0 && (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
          {singleArticles.map(article => (
            <ProductCard product={article} variant="full" />
          ))}
        </div>
      )}

      <!-- Artikkelikokoelmat -->
      <div class="space-y-6">
        {articleCollections.map(col => (
          <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-serif text-lg font-bold text-[#1a3a2a]">{col.title}</h3>
              <div class="shrink-0 text-right">
                <span class="block text-lg font-bold text-[#1a3a2a]">€{col.priceAll}</span>
                <span class="text-xs text-[#6b7280]">kaikki {col.articleCount} artikkelia</span>
              </div>
            </div>
            <p class="text-sm text-[#6b7280] mb-4">€{col.pricePerArticle} / yksittäinen artikkeli · PDF sähköpostitse</p>
            <ul class="grid sm:grid-cols-2 gap-1 text-sm text-[#4a4a4a] mb-4">
              {col.articles.map(a => (
                <li class="flex items-center gap-1.5">
                  <span class="text-[#2d6a4f]">•</span> {a}
                </li>
              ))}
            </ul>
            <a
              href={col.orderUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-[#1a3a2a] text-white px-5 py-2.5 rounded-md font-medium hover:bg-[#2d6a4f] transition-colors text-sm"
            >
              Tilaa artikkelit →
            </a>
            <button
              class="add-to-cart-btn inline-flex items-center gap-2 border border-[#1a3a2a] text-[#1a3a2a] px-5 py-2.5 rounded-md font-medium hover:bg-[#1a3a2a] hover:text-white transition-colors text-sm"
              data-id={col.id}
              data-title={col.title}
              data-price={col.priceAll}
              data-shipping="0"
              data-type="article-collection"
              data-image=""
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              Lisää koriin (€{col.priceAll})
            </button>
          </div>
        ))}
      </div>
      <p class="text-sm text-[#6b7280] mt-4 italic">
        Artikkeleita ei saa jakaa muille ilman tekijänoikeusomistajan lupaa.
      </p>
    </section>

    <div class="p-5 bg-[#f5f0e8] border border-[#e5d9c3] rounded-lg text-sm text-[#4a4a4a]">
      Kysymyksiä tilaamisesta?
      <a href="mailto:jarle@toisetaijat.fi" class="text-[#2d6a4f] hover:underline font-medium ml-1">jarle@toisetaijat.fi</a>
    </div>

  </div>
</BaseLayout>

<script>
  import { addItem } from '../scripts/cart';
  import type { CartItem } from '../scripts/cart';

  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.add-to-cart-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const item: CartItem = {
      id: btn.dataset.id!,
      title: btn.dataset.title!,
      price: parseFloat(btn.dataset.price!),
      shippingPrice: parseFloat(btn.dataset.shipping ?? '0'),
      type: (btn.dataset.type as CartItem['type']) ?? 'article-collection',
      quantity: 1,
      image: btn.dataset.image || undefined,
    };

    addItem(item);

    const original = btn.innerHTML;
    btn.innerHTML = '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Lisätty!';
    btn.disabled = true;
    setTimeout(() => {
      btn.innerHTML = original;
      btn.disabled = false;
    }, 1500);
  });
</script>
