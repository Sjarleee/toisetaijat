---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Myynissä" description="Tilaa Matti J. Kankaanpään kirjoja ja artikkeleita">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-[#1a3a2a] mb-2">Myynissä</h1>
    <p class="text-[#6b7280] mb-4 text-lg">Kirjat ja artikkelikokoelmat tilattavissa.</p>

    <!-- Shipping notice -->
    <div class="bg-[#d4a843]/10 border border-[#d4a843]/40 rounded-lg p-4 mb-10 text-sm text-[#6b4f0a]">
      <strong>Toimitusaikataulu:</strong> Asun ulkomailla, mutta käyn Suomessa säännöllisesti.
      Seuraava mahdollisuus lähettää tilauksia:
      <ul class="mt-2 list-disc list-inside space-y-0.5">
        <li>22–29 huhtikuuta</li>
        <li>20 toukokuuta – 24 heinäkuuta</li>
      </ul>
      <p class="mt-2">Jos jokin kirja kiinnostaa, ota yhteyttä etukäteen.</p>
    </div>

    <!-- KIRJAT -->
    <section class="mb-14">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-6">Kirjat</h2>
      <div class="space-y-4">

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Suomalainen ratsuväki Ruotsin ajalla</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Porvoo 2016. 790 s. ISBN 978-952-99106-9-4.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Suuri Pohjansota, Iso Viha ja suomalaiset</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Jyväskylä 2001. 464 s. ISBN 952-91-3934-9.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Ruoveden komppanian miehet Suomen sodassa</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Jyväskylä 2011. ISBN 978-952-99106-8-7.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Suur-Ruoveden vanhimmat rippikirjat</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Virrat 1983. 220 s. ISBN 951-99502-5-7.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Toiset Aijat II</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Turku 1985. ISBN 951-99640-8-8.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Karjalainen Karilainen</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Jyväskylä 2006. 238 s. ISBN 952-99106-6-5.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

        <div class="flex gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm items-start">
          <div class="flex-1">
            <h3 class="font-serif text-base font-bold text-[#1a3a2a]">Ruoveden ja Keuruun käräjäpöytäkirjoista 1722–1746</h3>
            <p class="text-sm text-[#6b7280] mt-0.5">Jyväskylä 2008. 254 s. ISBN 978-952-99106-7-0.</p>
          </div>
          <div class="shrink-0 text-right">
            <a href="mailto:jarle@toisetaijat.fi" class="inline-block bg-[#1a3a2a] text-white text-sm px-4 py-2 rounded-md hover:bg-[#2d6a4f] transition-colors">Kysy hintaa</a>
          </div>
        </div>

      </div>
      <p class="text-sm text-[#6b7280] mt-4">
        Muita kirjoja: katso <a href="/kirjat" class="text-[#2d6a4f] hover:underline">julkaisuluettelo</a>. Saatavuus vaihtelee — kysy sähköpostitse.
      </p>
    </section>

    <!-- E-KIRJAT -->
    <section class="mb-14">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-6">E-kirjat Google Play -kaupasta</h2>
      <ul class="space-y-2 text-sm text-[#4a4a4a]">
        <li>→ <a href="https://play.google.com/store/books/details/Matti_J_Kankaanp%C3%A4%C3%A4_Karjalan_Ratsurykmentti_Matrikk?id=fx4REAAAQBAJ" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Karjalan Ratsurykmentti – Matrikkeli 1700–1737</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=H4mvDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Ruoveden ja Keuruun käräjäpöytäkirjoista 1683–1711</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=8I6vDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Tyrvään vanhimmat rippikirjat 1693–1722</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=QfemDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Porin läänin jalkaväkirykmentin pääkatselmusrulla 1728</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=R_RRDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Viipurin ja Savonlinnan läänin henkikirja 1701 – Osa I</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=YfRRDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Viipurin ja Savonlinnan läänin henkikirja 1701 – Osa II</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=O2nVDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Toiset Aijat I</a></li>
        <li>→ <a href="https://play.google.com/store/books/details?id=Q7zjDwAAQBAJ&PAffiliateID=1011l9KyN" class="text-[#2d6a4f] hover:underline" target="_blank" rel="noopener">Lundin Taistelu 1676 ja suomalainen ratsuväki</a></li>
      </ul>
    </section>

    <!-- ARTIKKELIKOKOELMAT -->
    <section class="mb-12">
      <h2 class="font-serif text-2xl font-bold text-[#1a3a2a] border-b border-gray-200 pb-3 mb-2">Artikkelikokoelmat</h2>
      <p class="text-sm text-[#6b7280] mb-6">
        PDF-artikkeleita katselmusrullatutkimuksista. Toimitetaan sähköpostitse. €4 per artikkeli tai kaikki sarjan artikkelit yhteishintaan.
      </p>
      <div class="space-y-6">

        <!-- Uudenmaan Ratsurykmentti -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-serif text-lg font-bold text-[#1a3a2a]">Uudenmaan Ratsurykmentti 1641–1809</h3>
            <div class="shrink-0 text-right">
              <span class="block text-lg font-bold text-[#1a3a2a]">€80</span>
              <span class="text-xs text-[#6b7280]">kaikki 27 artikkelia</span>
            </div>
          </div>
          <p class="text-sm text-[#6b7280] mb-4">€4 / yksittäinen artikkeli · PDF sähköpostitse</p>
          <ul class="grid sm:grid-cols-2 gap-1 text-sm text-[#4a4a4a] mb-4">
            {[1641,1642,1643,1647,1649,1654,1655,'1655–1656 luettelovertailu',1659,1698,1700,1706,1712,1720,1728,1729,1743,1762,1767,1779,1787,1789,1790,1795,1800,1806,1809].map(y => (
              <li class="flex items-center gap-1.5">
                <span class="text-[#2d6a4f]">•</span> Uudenmaan Ratsurykmentti {y}
              </li>
            ))}
          </ul>
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSdafbB5W_AJYPs7i2woFzE_j-FFdsqrrtSy1w29JlyTknvdJw/viewform"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#1a3a2a] text-white px-5 py-2.5 rounded-md font-medium hover:bg-[#2d6a4f] transition-colors text-sm"
          >
            Tilaa artikkelit →
          </a>
        </div>

        <!-- Viipurin läänintilit -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-serif text-lg font-bold text-[#1a3a2a]">Viipurin läänintilit 1635–1724</h3>
            <div class="shrink-0 text-right">
              <span class="block text-lg font-bold text-[#1a3a2a]">€70</span>
              <span class="text-xs text-[#6b7280]">kaikki 23 artikkelia</span>
            </div>
          </div>
          <p class="text-sm text-[#6b7280] mb-4">€4 / yksittäinen artikkeli · PDF sähköpostitse</p>
          <ul class="grid sm:grid-cols-2 gap-1 text-sm text-[#4a4a4a] mb-4">
            {[1635,1639,'1655–1666',1665,1670,1673,1682,1683,1697,1699,1700,1701,1702,1703,1705,1706,1707,1708,1709,1710,1711,1712,1724].map(y => (
              <li class="flex items-center gap-1.5">
                <span class="text-[#2d6a4f]">•</span> Viipurin läänintilit {y}
              </li>
            ))}
          </ul>
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSe9Wy0K3ahk9ws3qrlb3rX5ZZ1UyEhyjF-nex9tFbbXe7KrFQ/viewform"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#1a3a2a] text-white px-5 py-2.5 rounded-md font-medium hover:bg-[#2d6a4f] transition-colors text-sm"
          >
            Tilaa artikkelit →
          </a>
        </div>

      </div>
      <p class="text-sm text-[#6b7280] mt-4 italic">
        Artikkeleita ei saa jakaa muille ilman tekijänoikeusomistajan lupaa.
      </p>
    </section>

    <div class="p-5 bg-[#f5f0e8] border border-[#e5d9c3] rounded-lg text-sm text-[#4a4a4a]">
      Kysymyksiä tilaamisesta?
      <a href="mailto:jarle@toisetaijat.fi" class="text-[#2d6a4f] hover:underline font-medium ml-1">jarle@toisetaijat.fi</a>
    </div>

  </div>
</BaseLayout>
