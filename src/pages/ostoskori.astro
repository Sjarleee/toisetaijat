---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ostoskori" description="Tarkista ostoskorisi ja siirry tilaukseen.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl font-bold text-[#1a3a2a] mb-8">Ostoskori</h1>
    <div id="cart-root">
      <p class="text-[#78716c]">Ladataan…</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { getItems, removeItem, updateQuantity, getShipping, getSubtotal } from '../scripts/cart';

  function render() {
    const root = document.getElementById('cart-root');
    if (!root) return;

    const items = getItems();

    if (items.length === 0) {
      root.innerHTML = `
        <div class="text-center py-16">
          <svg class="w-16 h-16 text-gray-200 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <p class="text-[#44403c] mb-6">Ostoskorisi on tyhjä.</p>
          <a href="/myynissa" class="inline-flex items-center gap-2 bg-[#1a3a2a] text-white px-6 py-2.5 rounded-md font-medium hover:bg-[#2d6a4f] transition-colors">
            Katso tuotteet →
          </a>
        </div>
      `;
      return;
    }

    const subtotal = getSubtotal(items);
    const shipping = getShipping(items);
    const total = subtotal + shipping;
    const hasBooks = items.some(i => i.type === 'book');
    const hasCollections = items.some(i => i.type === 'article-collection');

    root.innerHTML = `
      <div class="space-y-3 mb-8">
        ${items.map(item => `
          <div class="flex items-center gap-4 bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
            ${item.image
              ? `<img src="${item.image}" alt="${item.title}" class="w-14 h-14 object-contain rounded shrink-0 bg-gray-50">`
              : `<div class="w-14 h-14 rounded shrink-0 bg-gray-100 flex items-center justify-center text-gray-300">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </div>`
            }
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-[#1a3a2a] text-sm leading-snug">${item.title}</p>
              <p class="text-xs text-[#78716c] mt-0.5">${item.type === 'article-collection' ? 'PDF-artikkelit — toimitetaan sähköpostitse' : 'Kirja'}</p>
            </div>
            ${item.type === 'book' ? `
              <div class="flex items-center gap-1 shrink-0">
                <button class="qty-dec w-7 h-7 rounded border border-gray-400 hover:bg-gray-100 text-base font-medium flex items-center justify-center" data-id="${item.id}" aria-label="Vähennä ${item.title} määrää">−</button>
                <span class="w-7 text-center text-sm font-semibold" aria-live="polite">${item.quantity}</span>
                <button class="qty-inc w-7 h-7 rounded border border-gray-400 hover:bg-gray-100 text-base font-medium flex items-center justify-center" data-id="${item.id}" aria-label="Lisää ${item.title} määrää">+</button>
              </div>
            ` : `<span class="text-sm text-[#44403c] shrink-0">×${item.quantity}</span>`}
            <div class="text-right shrink-0 min-w-[52px]">
              <p class="font-bold text-[#1a3a2a]">€${(item.price * item.quantity)}</p>
            </div>
            <button class="remove-btn ml-1 text-gray-300 hover:text-red-400 transition-colors shrink-0" data-id="${item.id}" aria-label="Poista">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        `).join('')}
      </div>

      <div class="bg-[#f5f0e8] border border-[#e5d9c3] rounded-lg p-5 mb-6">
        <div class="space-y-1.5 text-sm mb-3">
          ${items.map(i => `
            <div class="flex justify-between text-[#4a4a4a]">
              <span>${i.title}${i.quantity > 1 ? ` ×${i.quantity}` : ''}</span>
              <span>€${i.price * i.quantity}</span>
            </div>
          `).join('')}
        </div>
        ${hasBooks && shipping > 0 ? `
          <div class="flex justify-between text-sm text-[#44403c] border-t border-[#d4b896] pt-2">
            <span>Arvioitu postitus</span>
            <span>€${shipping}</span>
          </div>
        ` : ''}
        <div class="flex justify-between font-bold text-lg border-t border-[#d4b896] pt-2 mt-2 text-[#1a3a2a]">
          <span>Arvioitu yhteensä</span>
          <span>€${total}</span>
        </div>
        <p class="text-xs text-[#78716c] mt-2">
          ${hasBooks ? 'Todelliset toimituskulut vahvistetaan tilauksessa. ' : ''}
          ${hasCollections ? 'PDF-artikkelit toimitetaan sähköpostitse maksun jälkeen.' : ''}
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a href="/myynissa" class="px-5 py-2.5 rounded-md border border-gray-400 text-sm font-medium text-[#4a4a4a] hover:bg-gray-50 transition-colors">
          ← Jatka ostoksia
        </a>
        <a href="/tilaus" class="flex-1 min-w-[200px] bg-[#d4a843] text-[#1a3a2a] text-center px-5 py-2.5 rounded-md font-bold hover:bg-[#c9a040] transition-colors text-sm">
          Siirry tilaukseen →
        </a>
      </div>
    `;

    // Qty buttons
    root.querySelectorAll('.qty-dec').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        const item = getItems().find(i => i.id === id);
        if (item) updateQuantity(id, item.quantity - 1);
        render();
      });
    });
    root.querySelectorAll('.qty-inc').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        const item = getItems().find(i => i.id === id);
        if (item) updateQuantity(id, item.quantity + 1);
        render();
      });
    });
    root.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        removeItem((btn as HTMLElement).dataset.id!);
        render();
      });
    });
  }

  render();
  window.addEventListener('cart-updated', render);
</script>
