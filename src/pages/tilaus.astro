---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const frontpage = await getEntry('pages', 'etusivu');
const { shippingNotice, shippingNoticeVisible, vatRate = '13,5' } = frontpage.data;
---

<BaseLayout title="Tilaus" description="Täytä tilauslomake.">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="font-serif text-3xl font-bold text-[#1a3a2a] mb-6">Tilaus</h1>

    <!-- Global shipping notice -->
    {shippingNoticeVisible !== false && shippingNotice && (
    <div class="flex items-start gap-3 bg-[#8b6914]/10 border-2 border-[#8b6914]/50 rounded-lg p-4 mb-6 text-[#6b4f0a]">
      <span class="text-2xl shrink-0">📦</span>
      <div>
        <p class="font-bold text-sm uppercase tracking-wide mb-0.5">Postitusaikataulu</p>
        <p class="text-sm leading-relaxed">{shippingNotice}</p>
      </div>
    </div>
    )}

    <!-- Seller info -->
    <div class="bg-white border border-gray-200 rounded-lg px-5 py-4 mb-6 text-sm text-[#44403c]">
      <p class="font-semibold text-[#1a3a2a] mb-1">Myyjä</p>
      <p>T:mi Toiset Aijat &middot; Y-tunnus 2901392-1</p>
      <p>Jarle M. Alvheim, Skullerudstubben 24, 1188 Oslo, Norway</p>
      <p><a href="mailto:jarle&#64;toisetaijat.fi" class="text-[#2d6a4f] hover:underline">jarle&#64;toisetaijat.fi</a></p>
    </div>

    <!-- Order summary (populated client-side) -->
    <div id="order-summary" class="bg-[#f5f0e8] border border-[#e5d9c3] rounded-lg p-4 mb-8 text-sm" data-vat-rate={vatRate}>
      <p class="text-[#78716c]">Ladataan tilauksen tietoja…</p>
    </div>

    <!-- Redirect if cart is empty -->
    <div id="empty-cart-msg" class="hidden text-center py-8">
      <p class="text-[#44403c] mb-4">Ostoskorisi on tyhjä.</p>
      <a href="/myynissa" class="text-[#2d6a4f] hover:underline">← Takaisin tuotteisiin</a>
    </div>

    <!-- Finland-only notice (shown only when cart has books) -->
    <div id="finland-notice" class="hidden bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-800">
      <strong>Huom:</strong> Kirjatilauksia toimitetaan ainoastaan Suomeen.
      PDF-artikkelit toimitetaan sähköpostitse kaikkialle.
    </div>

    <!-- Checkout form -->
    <form id="order-form" class="space-y-5" autocomplete="on" novalidate>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="firstName">Etunimi *</label>
          <input id="firstName" name="firstName" type="text" required autocomplete="shipping given-name"
            class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="lastName">Sukunimi *</label>
          <input id="lastName" name="lastName" type="text" required autocomplete="shipping family-name"
            class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="email">Sähköpostiosoite *</label>
        <input id="email" name="email" type="email" required autocomplete="email"
          class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
      </div>

      <div id="phone-field">
        <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="phone">
          Matkapuhelin *
          <span class="font-normal text-[#44403c] text-xs ml-1">(esim. +358401234567)</span>
        </label>
        <input id="phone" name="phone" type="tel" required autocomplete="shipping tel"
          pattern="\+?[0-9\s\-]{6,20}"
          placeholder="+358..."
          title="Syötä puhelinnumero"
          class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
      </div>

      <div id="shipping-fields">
        <div class="mb-4">
          <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="address">Katuosoite *</label>
          <input id="address" name="address" type="text" required autocomplete="shipping street-address"
            class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="postalCode">Postinumero *</label>
            <input id="postalCode" name="postalCode" type="text" required autocomplete="shipping postal-code"
              pattern="[0-9]{5}"
              maxlength="5"
              placeholder="00100"
              title="Syötä viisinumeroinen suomalainen postinumero"
              class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="city">Kaupunki *</label>
            <input id="city" name="city" type="text" required autocomplete="shipping address-level2"
              class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent" />
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-[#1a3a2a] mb-1">Maa</label>
          <input type="text" value="Suomi" readonly
            class="w-full border border-gray-200 rounded-md px-3 py-2 text-sm bg-gray-50 text-[#78716c] cursor-default" />
          <input type="hidden" name="country" value="Suomi" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-[#1a3a2a] mb-1" for="notes">Lisätiedot</label>
        <textarea id="notes" name="notes" rows="3" placeholder="Esim. useampi kappale tai erityistoiveet"
          class="w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2d6a4f] focus:border-transparent resize-none"></textarea>
      </div>

      <!-- Terms -->
      <div class="flex items-start gap-3">
        <input id="terms" name="terms" type="checkbox" required
          class="mt-0.5 w-4 h-4 accent-[#2d6a4f] shrink-0" />
        <label for="terms" class="text-sm text-[#4a4a4a]">
          Hyväksyn <a href="/toimitusehdot" target="_blank" class="text-[#2d6a4f] hover:underline">toimitusehdot</a> *
        </label>
      </div>

      <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-md p-3 text-sm text-red-700"></div>

      <div class="pt-2 flex flex-wrap gap-3">
        <a href="/ostoskori" class="px-5 py-2.5 rounded-md border border-gray-400 text-sm font-medium text-[#4a4a4a] hover:bg-gray-50 transition-colors">
          ← Ostoskori
        </a>
        <button id="submit-btn" type="submit"
          class="flex-1 min-w-[200px] bg-[#1a3a2a] text-white px-6 py-2.5 rounded-md font-bold hover:bg-[#2d6a4f] transition-colors text-sm disabled:opacity-60 disabled:cursor-not-allowed">
          Maksa MobilePay:llä →
        </button>
      </div>

      <p class="text-xs text-[#78716c]">
        Sinut ohjataan MobilePay-sovellukseen maksua varten. Maksu veloitetaan heti vahvistuksen jälkeen.
        PDF-artikkelit toimitetaan sähköpostitse maksun jälkeen.
      </p>
    </form>
  </div>
</BaseLayout>

<script>
  import { getItems, getShipping, getSubtotal, clearCart, getVat } from '../scripts/cart';

  const items = getItems();
  const summary = document.getElementById('order-summary')!;
  const vatRateLabel = summary.dataset.vatRate ?? '13,5';
  const form = document.getElementById('order-form') as HTMLFormElement;
  const emptyMsg = document.getElementById('empty-cart-msg')!;
  const shippingFields = document.getElementById('shipping-fields')!;
  const finlandNotice = document.getElementById('finland-notice')!;
  const phoneField = document.getElementById('phone-field')!;
  const hasBooks = items.some(i => i.type === 'book');

  // Redirect if cart empty
  if (items.length === 0) {
    emptyMsg.classList.remove('hidden');
    form.classList.add('hidden');
    summary.innerHTML = '';
  } else {
    const subtotal = getSubtotal(items);
    const shipping = getShipping(items);
    const total = subtotal + shipping;
    const vatAmount = getVat(subtotal);
    const exVat = subtotal - vatAmount;

    summary.innerHTML = `
      <h2 class="font-semibold text-[#1a3a2a] mb-2">Tilauksesi</h2>
      <ul class="space-y-1 mb-3">
        ${items.map(i => `
          <li class="flex justify-between">
            <span>${i.title}${i.quantity > 1 ? ` ×${i.quantity}` : ''}</span>
            <span class="font-medium">€${i.price * i.quantity}</span>
          </li>
        `).join('')}
      </ul>
      ${hasBooks && shipping > 0 ? `
        <div class="flex justify-between text-[#44403c] border-t border-[#d4b896] pt-2 mb-1">
          <span>Arvioitu postitus</span><span>€${shipping}</span>
        </div>
      ` : ''}
      <div class="flex justify-between font-bold text-[#1a3a2a] border-t border-[#d4b896] pt-1">
        <span>Arvioitu yhteensä</span><span>€${total}</span>
      </div>
      <div class="mt-2 pt-2 border-t border-[#e5d9c3] text-xs text-[#78716c] space-y-0.5">
        <div class="flex justify-between"><span>Veroton hinta</span><span>€${exVat.toFixed(2)}</span></div>
        <div class="flex justify-between"><span>ALV ${vatRateLabel} %</span><span>€${vatAmount.toFixed(2)}</span></div>
      </div>
    `;

    // GA4 begin_checkout
    try {
      const gtag = (window as any).gtag;
      if (typeof gtag === 'function') {
        gtag('event', 'begin_checkout', {
          currency: 'EUR',
          value: total,
          items: items.map((item, index) => ({
            item_id: item.id,
            item_name: item.title,
            price: item.price,
            quantity: item.quantity,
            item_category: item.type === 'book' ? 'Kirja' : 'Artikkelikokoelma',
            index,
          })),
        });
      }
    } catch {}

    if (hasBooks) {
      finlandNotice.classList.remove('hidden');
    } else {
      // Digital only: hide shipping address, payment method, phone
      shippingFields.querySelectorAll('input').forEach(i => i.removeAttribute('required'));
      shippingFields.innerHTML = `<p class="text-sm text-[#44403c] bg-blue-50 border border-blue-100 rounded-md px-4 py-3">
        Tilaus sisältää vain digitaalisia tuotteita — toimitusosoitetta ei tarvita.
      </p>`;
      phoneField.querySelector('input')?.removeAttribute('required');
      phoneField.querySelector('label span')?.remove();
    }
  }

  // Pre-fill form from previous attempt (stored in sessionStorage)
  try {
    const raw = sessionStorage.getItem('last_order');
    if (raw) {
      const prev = JSON.parse(raw);
      const nameParts = (prev.name ?? '').split(' ');
      const setVal = (id: string, val: string) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && val) el.value = val;
      };
      setVal('firstName', nameParts.slice(0, -1).join(' ') || nameParts[0] || '');
      setVal('lastName', nameParts.length > 1 ? nameParts[nameParts.length - 1] : '');
      setVal('email', prev.email ?? '');
      setVal('phone', prev.phone ?? '');
      setVal('address', prev.address ?? '');
      setVal('postalCode', prev.postalCode ?? '');
      setVal('city', prev.city ?? '');
      const notesEl = document.getElementById('notes') as HTMLTextAreaElement | null;
      if (notesEl && prev.notes) notesEl.value = prev.notes;
    }
  } catch {}

  // Form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorBox = document.getElementById('form-error')!;
    errorBox.classList.add('hidden');

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Lähetetään…';

    const fd = new FormData(form);
    const orderId = 'TA-' + Date.now().toString(36).toUpperCase();
    const orderedAt = new Date().toISOString();

    const order = {
      orderId,
      orderedAt,
      name: `${fd.get('firstName')} ${fd.get('lastName')}`.trim(),
      email: fd.get('email') as string,
      phone: fd.get('phone') as string || '',
      address: fd.get('address') as string || '',
      postalCode: fd.get('postalCode') as string || '',
      city: fd.get('city') as string || '',
      country: fd.get('country') as string || '',
      notes: fd.get('notes') as string || '',
      vatAmount: getVat(getSubtotal()),
      paymentMethod: 'mobilepay',
      items: getItems(),
      subtotal: getSubtotal(),
      shipping: getShipping(),
      total: getSubtotal() + getShipping(),
    };

    try {
      // 1. Store order locally for confirmation page
      sessionStorage.setItem('last_order', JSON.stringify(order));

      // 2. Create MobilePay payment
      btn.textContent = 'Siirrytään maksuun…';
      const totalCents = Math.round((order.subtotal + order.shipping) * 100);
      const payRes = await fetch('/api/payment/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          orderId: order.orderId,
          amountCents: totalCents,
          phone: order.phone || undefined,
          description: `Kirjatilaus – Toiset Aijat (${order.orderId})`,
        }),
      });

      if (!payRes.ok) throw new Error(`Payment API ${payRes.status}`);
      const payData = await payRes.json() as { ok: boolean; redirectUrl?: string; error?: string };
      if (!payData.ok || !payData.redirectUrl) throw new Error(payData.error ?? 'No redirectUrl');

      // 4. Redirect to MobilePay (cart is cleared only after confirmed CAPTURED payment)
      window.location.href = payData.redirectUrl;
    } catch (err) {
      btn.disabled = false;
      btn.textContent = 'Lähetä tilaus →';
      errorBox.textContent = 'Tilauksen lähetys epäonnistui. Yritä uudelleen tai ota yhteyttä sähköpostitse: jarle@toisetaijat.fi';
      errorBox.classList.remove('hidden');
    }
  });
</script>
